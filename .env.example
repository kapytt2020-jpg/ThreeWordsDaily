# ═══════════════════════════════════════════════
# ThreeWordsDaily — Production Environment Config
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════

# ── LEARNING BOT (main user-facing bot) ──
LEARNING_BOT_TOKEN=your_learning_bot_token_here

# ── MARKETER BOT (outreach/leads + referral bot) ──
MARKETER_BOT_TOKEN=your_marketer_bot_token_here
MARKETER_BOT_USERNAME=YourMarketerBotUsername   # without @, used for referral links

# ── TEACHER BOT (Лекс — group grammar assistant) ──
TEACHER_BOT_TOKEN=your_teacher_bot_token_here

# ── ANALYST BOT (admin analytics) ──
ANALYST_BOT_TOKEN=your_analyst_bot_token_here

# ── TELEGRAM IDs ──
TELEGRAM_CHAT_ID=-100xxxxxxxxxx        # Group/channel where content is posted
ADMIN_CHAT_ID=xxxxxxxxxx               # Your personal Telegram ID for admin alerts

# ── OPENAI ──
OPENAI_API_KEY=sk-proj-...

# ── GOOGLE SHEETS (optional — leave empty to disable Sheets sync) ──
# Format: https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
SHEETS_API_URL=

# ── MINI APP ──
MINI_APP_URL=https://threewords-app.vercel.app

# ── DATABASE ──
# Path to SQLite database file (relative to project root)
DB_PATH=miniapp/threewords.db

# ── MINIAPP URL ──
MINIAPP_URL=https://t.me/ThreeWordsDailyBot/app
