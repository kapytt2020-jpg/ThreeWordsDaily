{
  "manifest_version": 3,
  "name": "Claude Bridge",
  "version": "1.0",
  "description": "Connects Claude to your browser",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Bridge"
  }
}
